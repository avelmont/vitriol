# --- Compilation Artifacts ---
# Ignores the shared workspace build directory
/target/

# --- IDEs and Editors ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Environment and Secrets ---
.env
.env.*

# --- Cargo Specifics ---
